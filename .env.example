# TaskBee — ИС быстрого поиска и заказа профессиональных услуг

APP_NAME=TaskBee
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

APP_KEY=

# PostgreSQL (Docker: хост db)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=taskbee
DB_USERNAME=taskbee_user
DB_PASSWORD=change_me_secure_password

# Redis (Docker: хост redis) — кэш, сессии, очереди
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Vite dev server (для Laravel в Docker)
VITE_DEV_SERVER_URL=http://localhost:5173
